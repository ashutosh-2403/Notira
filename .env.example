# ─── Jira ───────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_WEBHOOK_SECRET=your_webhook_secret

# ─── Notion ─────────────────────────────────────────────────────────────────
NOTION_API_TOKEN=your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id

# ─── Public URL (required for image proxying) ────────────────────────────────
# Set this to your ngrok/public URL so Notion can load Jira attachment images
# Example: https://your-tunnel.ngrok-free.app
APP_PUBLIC_URL=https://your-public-url.ngrok-free.app

# ─── AI Summary (Groq — free at console.groq.com) ────────────────────────────
GROQ_API_KEY=your_groq_api_key
